#Garnishments
garn <- read_excel (
  "garn.xlsx",
  sheet = 1
)
othergroupmaster <- read_excel (
  "garnothermaster.xlsx",
  sheet = 1
)
##Other Group special collections and clackamas- final is called df_wideother
othergroupsc <- garn %>%
  filter(`Other Groups` != "None") %>%
  filter(Team == "Special Collections")
othergroupcountsc <- othergroupsc %>%
  count(worker = worker, group = `Other Groups`)
othergroupcl <- garn %>%
  filter(`Other Groups` != "None") %>%
  filter(Team == "Clackamas DA")
othergroupcountcl <- othergroupcl %>%
  count(worker = Team, group = `Other Groups`)
Garnothersheet <- union(othergroupcountcl, othergroupcountsc)
garnishments <- othergroupmaster %>%
  left_join (Garnothersheet, by = "group")

df_wideother <- garnishments %>%
  pivot_wider (
    names_from = group,
    values_from = n,
    values_fill = 0
    ) %>%
  arrange(worker) %>%
  mutate(Total = rowSums(across(-worker), na.rm = FALSE))


##insurance only special collections- final is called insurancecountfinal
insurancegroup<- garn %>%
  filter(!is.na(`Insurance Name`))
insurancecountsc <- insurancegroup %>%
  count(worker = worker, name = "Insurance Company")
insurancecountfinal <- names %>%
  left_join(insurancecountsc, by = "worker")

#Bank group special collections and clackamas- final is called df_widebank
banksc <- garn %>%
  filter(`Bank Group` != "None") %>%
  filter(Team == "Special Collections")
bankclack <- garn %>%
  filter(`Bank Group` != "None") %>%
  filter(Team == "Clackamas DA")
bankcountsc <- banksc %>%
  count(worker = worker, group = `Bank Group`)
bankcountclack <- bankclack %>%
  count(worker = Team, group = `Bank Group`)

bankscandclack <- union(bankcountsc, bankcountclack)

allbanks <- names %>%
  left_join(bankscandclack, by = "worker")

df_widebank <- allbanks %>%
  pivot_wider (
    names_from = group,
    values_from = n,
    values_fill = 0
  ) %>%
  arrange(worker) %>%
  mutate(Total = rowSums(across(-worker), na.rm = FALSE))


